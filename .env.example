# OrderFlow AI — Unified Environment Variables

# OpenAI (for chat AI)
OPENAI_API_KEY=sk-...

# Backend (Hono on port 3001)
BACKEND_URL=http://localhost:3001

# Database (Turso/Neon)
DATABASE_URL=postgresql://...

# Redis (for rate limiting + call sessions)
REDIS_URL=redis://localhost:6379

# Twilio (for voice calls)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Groq (for voice agent LLM)
GROQ_API_KEY=gsk_...

# Skip Twilio signature validation in dev
ORDERFLOW_SKIP_TWILIO_SIGNATURE=1

# Restaurant
RESTAURANT_ID=sample
